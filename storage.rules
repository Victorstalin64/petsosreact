rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ==================== MASCOTAS ====================
    match /mascotas/{imagenId} {
      // Upload: solo usuarios autenticados, solo imágenes, max 5MB
      allow create: if request.auth != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;

      // Read: cualquier usuario puede ver imágenes de mascotas
      allow read: if true;

      // Update: solo el propietario (quien subió) puede actualizar
      allow update: if request.auth != null;

      // Delete: solo el propietario puede eliminar
      allow delete: if request.auth != null;
    }

    // ==================== REPORTES DE ANIMALES ====================
    match /reportes-animales/{imagenId} {
      // Upload: usuarios autenticados o anónimos, solo imágenes, max 5MB
      allow create: if request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;

      // Read: cualquier usuario puede ver imágenes de reportes
      allow read: if true;

      // Update: solo usuarios autenticados
      allow update: if request.auth != null;

      // Delete: solo usuarios autenticados
      allow delete: if request.auth != null;
    }

    // ==================== IMÁGENES GENERALES ====================
    match /petsos-images/{imagenId} {
      // Upload: solo usuarios autenticados
      allow create: if request.auth != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;

      // Read: cualquier usuario
      allow read: if true;

      // Update/Delete: solo usuarios autenticados
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
